generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                  @id @default(cuid())
  email                    String                  @unique
  name                     String?
  avatarUrl                String?
  passwordHash             String?
  sessions                 Session[]
  passwordResetTokens      PasswordResetToken[]
  memberships              WorkspaceMembership[]
  sentWorkspaceInvitations WorkspaceInvitation[]   @relation("WorkspaceInvitationInviter")
  ownedDeals               Deal[]                  @relation("DealOwner")
  ownedLeads               Lead[]                  @relation("LeadOwner")
  ownedPeople              Person[]                @relation("PersonOwner")
  ownedOrganizations       Organization[]          @relation("OrganizationOwner")
  ownedActivities          Activity[]              @relation("ActivityOwner")
  ownedContractSteps       DealContractStep[]      @relation("DealContractStepOwner")
  authoredNotes            Note[]                  @relation("NoteAuthor")
  createdWebForms          WebForm[]               @relation("WebFormCreator")
  createdEmailLogs         EmailLog[]              @relation("EmailLogCreator")
  createdEmailConnections  EmailConnection[]       @relation("EmailConnectionCreator")
  createdMeetingIntakes    MeetingIntake[]         @relation("MeetingIntakeCreator")
  emailConnectionSecrets   EmailConnectionSecret[] @relation("EmailConnectionSecretUser")
  aiPreferences            AiPreference[]
  assistantActionRequests  AssistantActionRequest[] @relation("AssistantActionRequestCreator")
  assistantTodayItemHides  AssistantTodayItemHide[]
  auditLogs                AuditLog[]
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  deletedAt                DateTime?
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([consumedAt])
}

model Workspace {
  id                          String                       @id @default(cuid())
  name                        String
  slug                        String                       @unique
  memberships                 WorkspaceMembership[]
  invitations                 WorkspaceInvitation[]
  pipelines                   Pipeline[]
  stages                      PipelineStage[]
  deals                       Deal[]
  leads                       Lead[]
  people                      Person[]
  organizations               Organization[]
  products                    Product[]
  dealLineItems               DealLineItem[]
  contractSteps               DealContractStep[]
  quotes                      Quote[]
  quoteItems                  QuoteItem[]
  quotePublicLinks            QuotePublicLink[]
  webForms                    WebForm[]
  webFormSubmissions          WebFormSubmission[]
  activities                  Activity[]
  notes                       Note[]
  emailLogs                   EmailLog[]
  emailLogActivityLinks       EmailLogActivityLink[]
  emailTemplates              EmailTemplate[]
  emailConnections            EmailConnection[]
  emailConnectionSecrets      EmailConnectionSecret[]
  customFields                CustomFieldDefinition[]
  customValues                CustomFieldValue[]
  savedViews                  SavedView[]
  goals                       Goal[]
  jobs                        Job[]
  meetingIntakes              MeetingIntake[]
  meetingActivityAssociations MeetingActivityAssociation[]
  aiPreferences               AiPreference[]
  assistantActionRequests     AssistantActionRequest[]
  assistantTodayItemHides     AssistantTodayItemHide[]
  auditLogs                   AuditLog[]
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  deletedAt                   DateTime?
}

model WorkspaceMembership {
  id          String         @id @default(cuid())
  workspaceId String
  userId      String
  role        MembershipRole @default(MEMBER)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id])
  user        User           @relation(fields: [userId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WorkspaceInvitation {
  id          String                    @id @default(cuid())
  workspaceId String
  email       String
  role        MembershipRole            @default(MEMBER)
  status      WorkspaceInvitationStatus @default(PENDING)
  invitedById String?
  workspace   Workspace                 @relation(fields: [workspaceId], references: [id])
  invitedBy   User?                     @relation("WorkspaceInvitationInviter", fields: [invitedById], references: [id])
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@unique([workspaceId, email, status])
  @@index([workspaceId, status])
  @@index([email, status])
  @@index([invitedById])
}

model Pipeline {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  description String?
  sortOrder   Int             @default(0)
  workspace   Workspace       @relation(fields: [workspaceId], references: [id])
  stages      PipelineStage[]
  deals       Deal[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  @@index([workspaceId])
}

model PipelineStage {
  id          String    @id @default(cuid())
  workspaceId String
  pipelineId  String
  name        String
  probability Int?
  sortOrder   Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  pipeline    Pipeline  @relation(fields: [pipelineId], references: [id])
  deals       Deal[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([workspaceId, pipelineId])
}

model Deal {
  id                          String                       @id @default(cuid())
  workspaceId                 String
  pipelineId                  String
  stageId                     String
  ownerId                     String?
  personId                    String?
  organizationId              String?
  title                       String
  valueCents                  Int?
  currency                    String                       @default("USD")
  status                      DealStatus                   @default(OPEN)
  expectedCloseAt             DateTime?
  wonAt                       DateTime?
  lostAt                      DateTime?
  workspace                   Workspace                    @relation(fields: [workspaceId], references: [id])
  pipeline                    Pipeline                     @relation(fields: [pipelineId], references: [id])
  stage                       PipelineStage                @relation(fields: [stageId], references: [id])
  owner                       User?                        @relation("DealOwner", fields: [ownerId], references: [id])
  person                      Person?                      @relation(fields: [personId], references: [id])
  organization                Organization?                @relation(fields: [organizationId], references: [id])
  lineItems                   DealLineItem[]
  contractSteps               DealContractStep[]
  quotes                      Quote[]
  activities                  Activity[]
  meetingActivityAssociations MeetingActivityAssociation[]
  notes                       Note[]
  emailLogs                   EmailLog[]
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  deletedAt                   DateTime?

  @@index([workspaceId, pipelineId, stageId])
  @@index([workspaceId, ownerId])
  @@index([workspaceId, personId])
  @@index([workspaceId, organizationId])
  @@index([workspaceId, wonAt])
  @@index([workspaceId, lostAt])
}

model DealContractStep {
  id                String             @id @default(cuid())
  workspaceId       String
  dealId            String
  ownerId           String?
  type              ContractStepType
  status            ContractStepStatus @default(NOT_STARTED)
  dueAt             DateTime?
  sentAt            DateTime?
  signedAt          DateTime?
  notes             String?
  externalReference String?
  workspace         Workspace          @relation(fields: [workspaceId], references: [id])
  deal              Deal               @relation(fields: [dealId], references: [id], onDelete: Cascade)
  owner             User?              @relation("DealContractStepOwner", fields: [ownerId], references: [id])
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?

  @@unique([workspaceId, dealId, type])
  @@index([workspaceId, dealId])
  @@index([workspaceId, ownerId])
  @@index([workspaceId, status])
}

model Product {
  id             String         @id @default(cuid())
  workspaceId    String
  name           String
  description    String?
  unitPriceCents Int
  currency       String         @default("USD")
  active         Boolean        @default(true)
  workspace      Workspace      @relation(fields: [workspaceId], references: [id])
  dealLineItems  DealLineItem[]
  quoteItems     QuoteItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  @@index([workspaceId, active])
  @@index([workspaceId, name])
}

model DealLineItem {
  id             String      @id @default(cuid())
  workspaceId    String
  dealId         String
  productId      String?
  productName    String
  description    String?
  quantity       Int
  unitPriceCents Int
  currency       String      @default("USD")
  lineTotalCents Int
  workspace      Workspace   @relation(fields: [workspaceId], references: [id])
  deal           Deal        @relation(fields: [dealId], references: [id])
  product        Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  quoteItems     QuoteItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([workspaceId, dealId])
  @@index([workspaceId, productId])
}

model Quote {
  id            String              @id @default(cuid())
  workspaceId   String
  dealId        String
  number        String
  status        QuoteStatus         @default(DRAFT)
  currency      String              @default("USD")
  subtotalCents Int
  discountType  QuoteAdjustmentType @default(NONE)
  discountValue Int                 @default(0)
  discountCents Int                 @default(0)
  taxType       QuoteAdjustmentType @default(NONE)
  taxValue      Int                 @default(0)
  taxCents      Int                 @default(0)
  totalCents    Int
  workspace     Workspace           @relation(fields: [workspaceId], references: [id])
  deal          Deal                @relation(fields: [dealId], references: [id])
  items         QuoteItem[]
  publicLinks   QuotePublicLink[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([workspaceId, number])
  @@index([workspaceId, dealId])
}

model QuoteItem {
  id             String        @id @default(cuid())
  workspaceId    String
  quoteId        String
  dealLineItemId String?
  productId      String?
  name           String
  description    String?
  quantity       Int
  unitPriceCents Int
  currency       String        @default("USD")
  lineTotalCents Int
  workspace      Workspace     @relation(fields: [workspaceId], references: [id])
  quote          Quote         @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  dealLineItem   DealLineItem? @relation(fields: [dealLineItemId], references: [id], onDelete: SetNull)
  product        Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([workspaceId, quoteId])
  @@index([workspaceId, dealLineItemId])
  @@index([workspaceId, productId])
}

model QuotePublicLink {
  id          String    @id @default(cuid())
  workspaceId String
  quoteId     String
  token       String    @unique
  expiresAt   DateTime?
  revokedAt   DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  quote       Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, quoteId])
  @@index([token, revokedAt])
}

model Lead {
  id                          String                       @id @default(cuid())
  workspaceId                 String
  ownerId                     String?
  personId                    String?
  organizationId              String?
  title                       String
  source                      String?
  status                      LeadStatus                   @default(NEW)
  workspace                   Workspace                    @relation(fields: [workspaceId], references: [id])
  owner                       User?                        @relation("LeadOwner", fields: [ownerId], references: [id])
  person                      Person?                      @relation(fields: [personId], references: [id])
  organization                Organization?                @relation(fields: [organizationId], references: [id])
  activities                  Activity[]
  meetingActivityAssociations MeetingActivityAssociation[]
  notes                       Note[]
  emailLogs                   EmailLog[]
  webFormSubmissions          WebFormSubmission[]
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  deletedAt                   DateTime?

  @@index([workspaceId, ownerId])
  @@index([workspaceId, personId])
  @@index([workspaceId, organizationId])
}

model WebForm {
  id                  String              @id @default(cuid())
  workspaceId         String
  createdById         String?
  name                String
  publicTitle         String
  publicDescription   String?
  token               String              @unique
  isEnabled           Boolean             @default(true)
  sourceLabel         String
  requireLeadTitle    Boolean             @default(false)
  workspace           Workspace           @relation(fields: [workspaceId], references: [id])
  createdBy           User?               @relation("WebFormCreator", fields: [createdById], references: [id], onDelete: SetNull)
  submissions         WebFormSubmission[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?

  @@index([workspaceId])
  @@index([workspaceId, isEnabled])
  @@index([token, isEnabled])
}

model WebFormSubmission {
  id               String    @id @default(cuid())
  workspaceId      String
  webFormId        String
  leadId           String?
  fingerprint      String
  leadTitle        String?
  personName       String?
  email            String?
  phone            String?
  organizationName String?
  message          String?
  workspace        Workspace @relation(fields: [workspaceId], references: [id])
  webForm          WebForm   @relation(fields: [webFormId], references: [id], onDelete: Cascade)
  lead             Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  submittedAt      DateTime  @default(now())

  @@index([workspaceId, webFormId, submittedAt])
  @@index([workspaceId, fingerprint, submittedAt])
  @@index([leadId])
}

model Person {
  id                             String                       @id @default(cuid())
  workspaceId                    String
  ownerId                        String?
  organizationId                 String?
  firstName                      String
  lastName                       String?
  email                          String?
  phone                          String?
  relationshipPersonalContext    String?
  relationshipCommunicationStyle String?
  relationshipBusinessConcerns   String?
  relationshipFollowUpReminders  String?
  relationshipInternalGuidance   String?
  workspace                      Workspace                    @relation(fields: [workspaceId], references: [id])
  owner                          User?                        @relation("PersonOwner", fields: [ownerId], references: [id])
  organization                   Organization?                @relation(fields: [organizationId], references: [id])
  deals                          Deal[]
  leads                          Lead[]
  activities                     Activity[]
  meetingActivityAssociations    MeetingActivityAssociation[]
  notes                          Note[]
  emailLogs                      EmailLog[]
  createdAt                      DateTime                     @default(now())
  updatedAt                      DateTime                     @updatedAt
  deletedAt                      DateTime?

  @@index([workspaceId])
  @@index([workspaceId, email])
  @@index([workspaceId, organizationId])
}

model Organization {
  id                          String                       @id @default(cuid())
  workspaceId                 String
  ownerId                     String?
  name                        String
  domain                      String?
  workspace                   Workspace                    @relation(fields: [workspaceId], references: [id])
  owner                       User?                        @relation("OrganizationOwner", fields: [ownerId], references: [id])
  people                      Person[]
  deals                       Deal[]
  leads                       Lead[]
  activities                  Activity[]
  meetingActivityAssociations MeetingActivityAssociation[]
  notes                       Note[]
  emailLogs                   EmailLog[]
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  deletedAt                   DateTime?

  @@index([workspaceId])
  @@index([workspaceId, ownerId])
}

model Activity {
  id                  String                       @id @default(cuid())
  workspaceId         String
  ownerId             String?
  dealId              String?
  leadId              String?
  personId            String?
  organizationId      String?
  type                ActivityType
  title               String
  description         String?
  dueAt               DateTime?
  completedAt         DateTime?
  workspace           Workspace                    @relation(fields: [workspaceId], references: [id])
  owner               User?                        @relation("ActivityOwner", fields: [ownerId], references: [id])
  deal                Deal?                        @relation(fields: [dealId], references: [id])
  lead                Lead?                        @relation(fields: [leadId], references: [id])
  person              Person?                      @relation(fields: [personId], references: [id])
  organization        Organization?                @relation(fields: [organizationId], references: [id])
  meetingAssociations MeetingActivityAssociation[]
  emailLogLinks       EmailLogActivityLink[]
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  deletedAt           DateTime?

  @@index([workspaceId, dueAt])
  @@index([workspaceId, ownerId])
  @@index([workspaceId, dealId])
}

model Note {
  id             String        @id @default(cuid())
  workspaceId    String
  authorId       String?
  dealId         String?
  leadId         String?
  personId       String?
  organizationId String?
  body           String
  workspace      Workspace     @relation(fields: [workspaceId], references: [id])
  author         User?         @relation("NoteAuthor", fields: [authorId], references: [id])
  deal           Deal?         @relation(fields: [dealId], references: [id])
  lead           Lead?         @relation(fields: [leadId], references: [id])
  person         Person?       @relation(fields: [personId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@index([workspaceId])
  @@index([workspaceId, dealId])
}

model EmailLog {
  id                    String                   @id @default(cuid())
  workspaceId           String
  emailConnectionId     String?
  createdById           String?
  dealId                String?
  leadId                String?
  personId              String?
  organizationId        String?
  subject               String
  body                  String
  direction             EmailDirection
  occurredAt            DateTime
  fromText              String?
  toText                String?
  ccText                String?
  provider              EmailConnectionProvider?
  providerMessageId     String?
  providerThreadId      String?
  providerLabels        Json?
  providerSnippet       String?
  smartLabelJson        Json?
  smartLabelProvider    String?
  smartLabelGeneratedAt DateTime?
  workspace             Workspace                @relation(fields: [workspaceId], references: [id])
  emailConnection       EmailConnection?         @relation(fields: [emailConnectionId], references: [id], onDelete: SetNull)
  createdBy             User?                    @relation("EmailLogCreator", fields: [createdById], references: [id])
  deal                  Deal?                    @relation(fields: [dealId], references: [id])
  lead                  Lead?                    @relation(fields: [leadId], references: [id])
  person                Person?                  @relation(fields: [personId], references: [id])
  organization          Organization?            @relation(fields: [organizationId], references: [id])
  activityLinks         EmailLogActivityLink[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@unique([workspaceId, provider, emailConnectionId, providerMessageId])
  @@index([workspaceId, occurredAt])
  @@index([workspaceId, emailConnectionId])
  @@index([workspaceId, dealId])
  @@index([workspaceId, leadId])
  @@index([workspaceId, personId])
  @@index([workspaceId, organizationId])
  @@index([workspaceId, smartLabelGeneratedAt])
}

model EmailLogActivityLink {
  id          String   @id @default(cuid())
  workspaceId String
  emailLogId  String
  activityId  String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  emailLog    EmailLog  @relation(fields: [emailLogId], references: [id], onDelete: Cascade)
  activity    Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([emailLogId, activityId])
  @@index([workspaceId, emailLogId])
  @@index([workspaceId, activityId])
}

model EmailTemplate {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  subject     String
  body        String
  active      Boolean   @default(true)
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, active])
  @@index([workspaceId, name])
}

model EmailConnection {
  id             String                  @id @default(cuid())
  workspaceId    String
  provider       EmailConnectionProvider
  status         EmailConnectionStatus   @default(NOT_CONFIGURED)
  accountEmail   String?
  displayName    String?
  scopes         Json?
  lastSyncAt     DateTime?
  lastSyncCursor String?
  lastError      String?
  createdById    String?
  workspace      Workspace               @relation(fields: [workspaceId], references: [id])
  createdBy      User?                   @relation("EmailConnectionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  secret         EmailConnectionSecret?
  emailLogs      EmailLog[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  deletedAt      DateTime?

  @@unique([workspaceId, provider, accountEmail, createdById])
  @@index([workspaceId, provider])
  @@index([workspaceId, status])
  @@index([createdById])
}

model EmailConnectionSecret {
  id                    String                  @id @default(cuid())
  workspaceId           String
  connectionId          String                  @unique
  userId                String
  provider              EmailConnectionProvider
  accountEmail          String
  scopes                Json?
  encryptedAccessToken  String
  encryptedRefreshToken String?
  accessTokenExpiresAt  DateTime?
  workspace             Workspace               @relation(fields: [workspaceId], references: [id])
  connection            EmailConnection         @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  user                  User                    @relation("EmailConnectionSecretUser", fields: [userId], references: [id])
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([workspaceId, provider])
  @@index([workspaceId, accountEmail])
  @@index([userId])
}

model CustomFieldDefinition {
  id          String                @id @default(cuid())
  workspaceId String
  entityType  CustomFieldEntityType
  name        String
  key         String
  fieldType   CustomFieldType
  required    Boolean               @default(false)
  options     Json?
  workspace   Workspace             @relation(fields: [workspaceId], references: [id])
  values      CustomFieldValue[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  deletedAt   DateTime?

  @@unique([workspaceId, entityType, key])
  @@index([workspaceId, entityType])
}

model CustomFieldValue {
  id          String                @id @default(cuid())
  workspaceId String
  fieldId     String
  entityType  CustomFieldEntityType
  entityId    String
  value       Json
  workspace   Workspace             @relation(fields: [workspaceId], references: [id])
  field       CustomFieldDefinition @relation(fields: [fieldId], references: [id])
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([fieldId, entityId])
  @@index([workspaceId, entityType, entityId])
}

model SavedView {
  id          String              @id @default(cuid())
  workspaceId String
  recordType  SavedViewRecordType
  name        String
  state       Json
  workspace   Workspace           @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([workspaceId, recordType])
}

model Goal {
  id          String    @id @default(cuid())
  workspaceId String
  type        GoalType
  periodStart DateTime
  periodEnd   DateTime
  currency    String
  targetCents Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, type, currency, periodStart])
  @@index([workspaceId, type, periodStart])
  @@index([workspaceId, currency, periodStart])
}

model Job {
  id          String     @id @default(cuid())
  workspaceId String?
  type        String
  payload     Json
  status      JobStatus  @default(PENDING)
  attempts    Int        @default(0)
  maxAttempts Int        @default(3)
  runAt       DateTime   @default(now())
  lockedAt    DateTime?
  lockedBy    String?
  processedAt DateTime?
  failedAt    DateTime?
  lastError   String?
  dedupeKey   String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, runAt])
  @@index([lockedAt])
  @@index([workspaceId])
  @@index([type, dedupeKey, status])
}

model MeetingIntake {
  id                          String                       @id @default(cuid())
  workspaceId                 String
  createdById                 String?
  sourceType                  MeetingIntakeSourceType
  originalFilename            String?
  originalMimeType            String?
  contextText                 String?
  rawText                     String?
  markdownText                String?
  status                      MeetingIntakeStatus          @default(DRAFT)
  analysisJson                Json?
  proposedChangesJson         Json?
  applyResultJson             Json?
  errorMessage                String?
  appliedAt                   DateTime?
  workspace                   Workspace                    @relation(fields: [workspaceId], references: [id])
  createdBy                   User?                        @relation("MeetingIntakeCreator", fields: [createdById], references: [id], onDelete: SetNull)
  meetingActivityAssociations MeetingActivityAssociation[]
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([createdById])
}

model MeetingActivityAssociation {
  id              String         @id @default(cuid())
  workspaceId     String
  activityId      String
  meetingIntakeId String?
  dealId          String?
  leadId          String?
  personId        String?
  organizationId  String?
  workspace       Workspace      @relation(fields: [workspaceId], references: [id])
  activity        Activity       @relation(fields: [activityId], references: [id], onDelete: Cascade)
  meetingIntake   MeetingIntake? @relation(fields: [meetingIntakeId], references: [id], onDelete: SetNull)
  deal            Deal?          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lead            Lead?          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  person          Person?        @relation(fields: [personId], references: [id], onDelete: Cascade)
  organization    Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@index([workspaceId, activityId])
  @@index([workspaceId, meetingIntakeId])
  @@index([workspaceId, dealId])
  @@index([workspaceId, leadId])
  @@index([workspaceId, personId])
  @@index([workspaceId, organizationId])
}

model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  actorId     String?
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  actor       User?     @relation(fields: [actorId], references: [id])
  createdAt   DateTime  @default(now())

  @@index([workspaceId, entityType, entityId])
  @@index([workspaceId, actorId])
}

model AiPreference {
  id                           String    @id @default(cuid())
  workspaceId                  String
  userId                       String
  emailSummaryLength           String    @default("short")
  recordSummaryStyle           String    @default("balanced")
  replyTone                    String    @default("warm")
  assistantDetailLevel         String    @default("balanced")
  diagnosticsDetailLevel       String    @default("simple")
  relationshipMemoryUsage      String    @default("conservative")
  meetingIntelligenceNoteStyle String    @default("structured")
  suggestionAggressiveness     String    @default("medium")
  naturalLanguageInstructions  String?
  assistantNamePreset          String    @default("Stella")
  assistantCustomName          String?
  assistantTonePreset          String    @default("warm_helpful")
  assistantHelpAreas           String?
  assistantPermissionMode      String    @default("review_first")
  onboardingGoals              String?
  workspace                    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  @@unique([workspaceId, userId])
  @@index([userId])
}

model AssistantActionRequest {
  id              String                       @id @default(cuid())
  workspaceId     String
  createdById     String?
  status          AssistantActionRequestStatus @default(PENDING)
  actionType      String
  objectType      String
  riskLevel       String
  confidence      String
  title           String
  targetLabel     String
  targetHref      String?
  sourceSummary   String?
  proposedPayload Json
  evidence        Json?
  warnings        Json?
  missingInfo     Json?
  workspace       Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy       User?                        @relation("AssistantActionRequestCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  rejectedAt      DateTime?
  appliedAt       DateTime?

  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, createdById, status])
  @@index([createdById, status])
}

model AssistantTodayItemHide {
  id           String    @id @default(cuid())
  workspaceId  String
  userId       String
  itemKey      String
  localDateKey String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([workspaceId, userId, itemKey, localDateKey])
  @@index([workspaceId, userId, localDateKey])
  @@index([userId, localDateKey])
}

